//@version=5
// NaatAI OrderFlow - all-in-one main-chart port of the naatai web chart.
// Includes: EMA 20/50/200, session VWAP, institutional supply/demand zones,
// auto-fib retracement, delta + cumulative delta, CVD divergence, BUY/SELL
// signals at candle close with printed ENTRY / SL / TP and shaded R/R boxes,
// per-candle volume + delta labels, and the NaatAI dashboard.
// Add "NaatAI Heikin Ashi Panel" (separate script) in a pane below to
// reproduce the bottom panel of the web chart.
indicator("NaatAI OrderFlow", "NaatAI", overlay=true,
     max_labels_count=500, max_lines_count=500, max_boxes_count=200)

// ----------------------------- Inputs ------------------------------
gT = "Trend layer"
showEMA  = input.bool(true, "EMA 20 / 50 / 200", group=gT)
showVWAP = input.bool(true, "Session VWAP",      group=gT)

gS = "Signals"
deltaThr = input.float(20,  "Delta threshold (%)",       minval=5, maxval=50, group=gS)
sigVolX  = input.float(1.2, "Min volume (x 50-bar avg)", step=0.1, group=gS)
htfTf    = input.timeframe("240", "Higher-timeframe trend", group=gS)
sigSpace = input.int(5,     "Min bars between signals",  minval=1, group=gS)
atrMult  = input.float(1.5, "Stop-loss = ATR x",         step=0.1, group=gS)
rr       = input.float(2.0, "Take-profit (R multiple)",  step=0.5, group=gS)

gZ = "Institutional zones"
showZones = input.bool(true, "Supply / demand zones",    group=gZ)
pivLen    = input.int(8,     "Zone pivot length",  minval=3, maxval=25, group=gZ)
zVolX     = input.float(1.15,"Zone volume spike (x avg)", step=0.05, group=gZ)
maxZones  = input.int(3,     "Max zones per side", minval=1, maxval=8, group=gZ)

gF = "Order flow / display"
lblCount = input.int(12,    "Candles with volume labels", minval=0, maxval=40, group=gF)
fibLen   = input.int(100,   "Swing lookback for fib",     minval=20, group=gF)
showFib  = input.bool(true, "Show fib retracement",       group=gF)
showTbl  = input.bool(true, "Show dashboard",             group=gF)

cGreen = #2ecc71
cRed   = #ff5c5c
cMut   = #8b98a9
cAmb   = #f5a623
cBlue  = #4d9fff
cViol  = #8b7cf0

// ------------------- Delta / CVD (deterministic) --------------------
// Delta is estimated from each candle's own OHLCV - how far the close sits
// inside the bar's range - so it is IDENTICAL on every account and every plan.
// (Tick-level bid/ask delta is not available in Pine. request.security_lower_tf
// returns a plan-dependent number of intrabars, which is exactly why the old
// version showed different Delta / Cum Delta on two accounts for the same pair.)
rng     = high - low
buyVol  = rng > 0 ? volume * (close - low) / rng : volume * 0.5
sellVol = rng > 0 ? volume * (high - close) / rng : volume * 0.5
delta   = buyVol - sellVol
deltaPct = volume > 0 ? delta / volume * 100 : 0.0
// Cumulative delta anchored to the UTC day, so it is comparable across accounts
// regardless of how much history each one happens to load.
newDay = timeframe.change("D")
var float cumDelta = 0.0
cumDelta := (newDay ? 0.0 : cumDelta) + delta

// ------------------------- Context ----------------------------------
rsi   = ta.rsi(close, 14)
atr   = ta.atr(14)
ema20 = ta.ema(close, 20)
ema50 = ta.ema(close, 50)
ema200 = ta.ema(close, 200)
vwap  = ta.vwap(hlc3)
htfUp = request.security(syminfo.tickerid, htfTf,
     ta.ema(close, 20) > ta.ema(close, 50)) == true

plot(showEMA  ? ema20  : na, "EMA 20",  color=cBlue, linewidth=1)
plot(showEMA  ? ema50  : na, "EMA 50",  color=#c98500, linewidth=1)
plot(showEMA  ? ema200 : na, "EMA 200", color=cViol, linewidth=2)
plot(showVWAP ? vwap   : na, "VWAP",    color=#d55181, linewidth=1, style=plot.style_circles)

// ------------- Per-candle volume + delta% labels --------------------
var label[] volLbls = array.new<label>()
if lblCount > 0 and barstate.isconfirmed
    array.push(volLbls, label.new(bar_index, high, "V:" + str.tostring(volume, format.volume),
         yloc=yloc.abovebar, style=label.style_none, textcolor=color.new(cMut, 15), size=size.tiny))
    array.push(volLbls, label.new(bar_index, low,
         (deltaPct >= 0 ? "+" : "") + str.tostring(deltaPct, "#") + "%",
         yloc=yloc.belowbar, style=label.style_none,
         textcolor=deltaPct >= 0 ? cGreen : cRed, size=size.tiny))
    while array.size(volLbls) > lblCount * 2
        label.delete(array.shift(volLbls))

// ------------- Auto fib retracement of last swing -------------------
hh = ta.highest(high, fibLen)
ll = ta.lowest(low, fibLen)
upSwing = ta.highestbars(high, fibLen) > ta.lowestbars(low, fibLen)
fibAt(r) => upSwing ? hh - (hh - ll) * r : ll + (hh - ll) * r
fib382 = fibAt(0.382)
fib500 = fibAt(0.5)
fib618 = fibAt(0.618)

var line  f1 = na
var line  f2 = na
var line  f3 = na
var label lf1 = na
var label lf2 = na
var label lf3 = na
if showFib and barstate.islast
    if na(f1)
        f1 := line.new(bar_index, fib382, bar_index, fib382, color=color.new(cBlue, 45), style=line.style_dotted)
        f2 := line.new(bar_index, fib500, bar_index, fib500, color=color.new(cAmb, 45), style=line.style_dotted)
        f3 := line.new(bar_index, fib618, bar_index, fib618, color=color.new(cGreen, 45), style=line.style_dotted)
        lf1 := label.new(bar_index, fib382, "", style=label.style_none, size=size.tiny)
        lf2 := label.new(bar_index, fib500, "", style=label.style_none, size=size.tiny)
        lf3 := label.new(bar_index, fib618, "", style=label.style_none, size=size.tiny)
    x0 = bar_index - fibLen
    x1 = bar_index + 15
    line.set_xy1(f1, x0, fib382)
    line.set_xy2(f1, x1, fib382)
    line.set_xy1(f2, x0, fib500)
    line.set_xy2(f2, x1, fib500)
    line.set_xy1(f3, x0, fib618)
    line.set_xy2(f3, x1, fib618)
    label.set_xy(lf1, x1, fib382)
    label.set_text(lf1, "0.382 " + str.tostring(fib382, format.mintick))
    label.set_textcolor(lf1, cBlue)
    label.set_xy(lf2, x1, fib500)
    label.set_text(lf2, "0.5 " + str.tostring(fib500, format.mintick))
    label.set_textcolor(lf2, cAmb)
    label.set_xy(lf3, x1, fib618)
    label.set_text(lf3, "0.618 " + str.tostring(fib618, format.mintick))
    label.set_textcolor(lf3, cGreen)

// ------------- Institutional supply/demand zones --------------------
zVolAvg = ta.sma(volume, 50)
ph = ta.pivothigh(high, pivLen, pivLen)
pl = ta.pivotlow(low, pivLen, pivLen)
var box[] supBoxes = array.new<box>()
var box[] demBoxes = array.new<box>()
if showZones and not na(ph) and volume[pivLen] > zVolX * zVolAvg[pivLen]
    top = high[pivLen]
    bot = math.max(open[pivLen], close[pivLen])
    if top > bot
        array.push(supBoxes, box.new(bar_index - pivLen, top, bar_index, bot,
             border_color=color.new(cRed, 55), bgcolor=color.new(cRed, 88), extend=extend.right,
             text="SUPPLY", text_color=color.new(cRed, 20), text_size=size.tiny, text_halign=text.align_left))
        if array.size(supBoxes) > maxZones
            box.delete(array.shift(supBoxes))
if showZones and not na(pl) and volume[pivLen] > zVolX * zVolAvg[pivLen]
    top = math.min(open[pivLen], close[pivLen])
    bot = low[pivLen]
    if top > bot
        array.push(demBoxes, box.new(bar_index - pivLen, top, bar_index, bot,
             border_color=color.new(cGreen, 55), bgcolor=color.new(cGreen, 88), extend=extend.right,
             text="DEMAND", text_color=color.new(cGreen, 20), text_size=size.tiny, text_halign=text.align_left))
        if array.size(demBoxes) > maxZones
            box.delete(array.shift(demBoxes))
// invalidate broken zones
if array.size(supBoxes) > 0
    for i = array.size(supBoxes) - 1 to 0
        b = array.get(supBoxes, i)
        if close > box.get_top(b) * 1.0015
            box.delete(b)
            array.remove(supBoxes, i)
if array.size(demBoxes) > 0
    for i = array.size(demBoxes) - 1 to 0
        b = array.get(demBoxes, i)
        if close < box.get_bottom(b) * 0.9985
            box.delete(b)
            array.remove(demBoxes, i)
inSupply = false
inDemand = false
if array.size(supBoxes) > 0
    for i = 0 to array.size(supBoxes) - 1
        b = array.get(supBoxes, i)
        if high >= box.get_bottom(b) and low <= box.get_top(b)
            inSupply := true
if array.size(demBoxes) > 0
    for i = 0 to array.size(demBoxes) - 1
        b = array.get(demBoxes, i)
        if high >= box.get_bottom(b) and low <= box.get_top(b)
            inDemand := true

// ------------- CVD divergence (price vs cumulative delta) -----------
phP = ta.pivothigh(high, 5, 5)
plP = ta.pivotlow(low, 5, 5)
var float lastPH = na
var float lastPHc = na
var float lastPL = na
var float lastPLc = na
bearDiv = false
bullDiv = false
if not na(phP)
    if not na(lastPH) and phP > lastPH and cumDelta[5] < lastPHc
        bearDiv := true
    lastPH := phP
    lastPHc := cumDelta[5]
if not na(plP)
    if not na(lastPL) and plP < lastPL and cumDelta[5] > lastPLc
        bullDiv := true
    lastPL := plP
    lastPLc := cumDelta[5]
plotshape(bearDiv, "Bearish CVD divergence", shape.triangledown, location.abovebar,
     color.new(cRed, 0), offset=-5, size=size.tiny, text="div")
plotshape(bullDiv, "Bullish CVD divergence", shape.triangleup, location.belowbar,
     color.new(cGreen, 0), offset=-5, size=size.tiny, text="div")

// ------------------------- Signal engine ----------------------------
volOK  = volume >= sigVolX * zVolAvg
buyOK  = deltaPct >= deltaThr  and htfUp     and rsi < 70 and volOK
sellOK = deltaPct <= -deltaThr and not htfUp and rsi > 30 and volOK
var int lastSigBar = na
canSig  = na(lastSigBar) or bar_index - lastSigBar >= sigSpace
buySig  = buyOK  and canSig and barstate.isconfirmed and bar_index > 50
sellSig = sellOK and canSig and barstate.isconfirmed and bar_index > 50

plotshape(buySig,  "BUY",  shape.triangleup,   location.belowbar, cGreen, size=size.small, text="BUY",  textcolor=cGreen)
plotshape(sellSig, "SELL", shape.triangledown, location.abovebar, cRed,   size=size.small, text="SELL", textcolor=cRed)

var line[]  sigLines = array.new<line>()
var label[] sigLbls  = array.new<label>()
var box[]   sigBoxes = array.new<box>()
if buySig or sellSig
    lastSigBar := bar_index
    entry = close
    sl = buySig ? entry - atr * atrMult : entry + atr * atrMult
    tp = buySig ? entry + (entry - sl) * rr : entry - (sl - entry) * rr
    xe = bar_index + 20
    array.push(sigBoxes, box.new(bar_index, math.max(entry, tp), xe, math.min(entry, tp),
         border_color=color.new(cGreen, 80), bgcolor=color.new(cGreen, 90)))
    array.push(sigBoxes, box.new(bar_index, math.max(entry, sl), xe, math.min(entry, sl),
         border_color=color.new(cRed, 80), bgcolor=color.new(cRed, 92)))
    array.push(sigLines, line.new(bar_index, entry, xe, entry, color=color.new(color.white, 30), style=line.style_dashed))
    array.push(sigLines, line.new(bar_index, sl, xe, sl, color=color.new(cRed, 20), style=line.style_dashed))
    array.push(sigLines, line.new(bar_index, tp, xe, tp, color=color.new(cGreen, 20), style=line.style_dashed))
    array.push(sigLbls, label.new(xe, entry, "ENTRY " + str.tostring(entry, format.mintick),
         style=label.style_label_left, color=color.new(color.gray, 60), textcolor=color.white, size=size.small))
    array.push(sigLbls, label.new(xe, sl, "SL " + str.tostring(sl, format.mintick) + " (-1R)",
         style=label.style_label_left, color=color.new(cRed, 60), textcolor=color.white, size=size.small))
    array.push(sigLbls, label.new(xe, tp, "TP " + str.tostring(tp, format.mintick) + " (+" + str.tostring(rr, "#.#") + "R)",
         style=label.style_label_left, color=color.new(cGreen, 60), textcolor=color.white, size=size.small))
    while array.size(sigBoxes) > 6
        box.delete(array.shift(sigBoxes))
    while array.size(sigLines) > 9
        line.delete(array.shift(sigLines))
    while array.size(sigLbls) > 9
        label.delete(array.shift(sigLbls))

// ------------- Next-candle probability (heuristic) ------------------
f_tanh(float x) =>
    xx = math.max(-10.0, math.min(10.0, x))
    e = math.exp(2 * xx)
    (e - 1) / (e + 1)
zoneScore = inDemand and not inSupply ? 0.4 : inSupply and not inDemand ? -0.4 : 0.0
score  = deltaPct / 25.0 + (htfUp ? 0.5 : -0.5) +
     (cumDelta > cumDelta[10] ? 0.4 : -0.4) + (close > ema20 ? 0.3 : -0.3) + zoneScore
upProb = math.max(15.0, math.min(85.0, 50 + 50 * f_tanh(score)))

// ------------------------- Dashboard --------------------------------
var table tbl = table.new(position.top_right, 2, 11,
     bgcolor=color.new(#131823, 8), border_color=color.new(#232b3a, 0), border_width=1)
if showTbl and barstate.islast
    txt = color.new(#e6edf3, 0)
    mut = color.new(cMut, 0)
    sigTxt = buyOK ? "BUY" : sellOK ? "SELL" : "WAIT"
    sigCol = buyOK ? cGreen : sellOK ? cRed : cAmb
    zTxt = inDemand ? "In demand" : inSupply ? "In supply" : "-"
    table.cell(tbl, 0, 0, "NaatAI OFC", text_color=cBlue, text_size=size.small)
    table.cell(tbl, 1, 0, timeframe.period, text_color=cBlue, text_size=size.small)
    table.cell(tbl, 0, 1, "Buy Vol", text_color=mut, text_size=size.small)
    table.cell(tbl, 1, 1, str.tostring(buyVol, format.volume), text_color=cGreen, text_size=size.small)
    table.cell(tbl, 0, 2, "Sell Vol", text_color=mut, text_size=size.small)
    table.cell(tbl, 1, 2, str.tostring(sellVol, format.volume), text_color=cRed, text_size=size.small)
    table.cell(tbl, 0, 3, "Delta", text_color=mut, text_size=size.small)
    table.cell(tbl, 1, 3, (delta >= 0 ? "+" : "") + str.tostring(delta, format.volume) +
         " (" + (deltaPct >= 0 ? "+" : "") + str.tostring(deltaPct, "#") + "%)",
         text_color=delta >= 0 ? cGreen : cRed, text_size=size.small)
    table.cell(tbl, 0, 4, "Cum Delta (day)", text_color=mut, text_size=size.small)
    table.cell(tbl, 1, 4, (cumDelta >= 0 ? "+" : "") + str.tostring(cumDelta, format.volume),
         text_color=cumDelta >= 0 ? cGreen : cRed, text_size=size.small)
    table.cell(tbl, 0, 5, "RSI(14)", text_color=mut, text_size=size.small)
    table.cell(tbl, 1, 5, str.tostring(rsi, "#.#"), text_color=txt, text_size=size.small)
    table.cell(tbl, 0, 6, "Fib 0.618", text_color=mut, text_size=size.small)
    table.cell(tbl, 1, 6, str.tostring(fib618, format.mintick), text_color=txt, text_size=size.small)
    table.cell(tbl, 0, 7, "Next candle", text_color=mut, text_size=size.small)
    table.cell(tbl, 1, 7, "UP " + str.tostring(upProb, "#") + "% / DN " + str.tostring(100 - upProb, "#") + "%",
         text_color=upProb >= 50 ? cGreen : cRed, text_size=size.small)
    table.cell(tbl, 0, 8, "Zone", text_color=mut, text_size=size.small)
    table.cell(tbl, 1, 8, zTxt, text_color=inDemand ? cGreen : inSupply ? cRed : txt, text_size=size.small)
    table.cell(tbl, 0, 9, "HTF trend (" + htfTf + ")", text_color=mut, text_size=size.small)
    table.cell(tbl, 1, 9, htfUp ? "UP" : "DOWN", text_color=htfUp ? cGreen : cRed, text_size=size.small)
    table.cell(tbl, 0, 10, "Signal", text_color=mut, text_size=size.small)
    table.cell(tbl, 1, 10, sigTxt, text_color=sigCol, text_size=size.normal)

// ------------------------------ Alerts ------------------------------
alertcondition(buySig,  "NaatAI BUY",  "NaatAI: BUY signal on {{ticker}} {{interval}}")
alertcondition(sellSig, "NaatAI SELL", "NaatAI: SELL signal on {{ticker}} {{interval}}")
alertcondition(bullDiv, "NaatAI bullish divergence", "NaatAI: bullish CVD divergence on {{ticker}} {{interval}}")
alertcondition(bearDiv, "NaatAI bearish divergence", "NaatAI: bearish CVD divergence on {{ticker}} {{interval}}")
