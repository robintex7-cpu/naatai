//@version=6
// NaatAI OrderFlow Candles v3
// ---------------------------
// Candle-replacement orderflow indicator.
//   * Volume-split candles: green part = buy volume share, red = sell share
//     (or classic delta-colored candles — switchable)
//   * Real-time buy/sell volume, delta and next-candle probability per bar
//   * Footprint cells with imbalance highlighting
//   * Auto support/resistance lines (pivots) + auto Fibonacci levels
//   * Non-repainting BUY/SELL signals (confirmed at close) with SL/TP labels
//   * Auto lower-TF volume engine and auto higher-TF trend filter — works on
//     every chart timeframe without re-tuning
//   * Left-side screener: watches your list of Binance pairs and shows which
//     ones have a BUY or SELL state right now
indicator("NaatAI OrderFlow Candles", "NaatAI OFC", overlay = true,
     max_labels_count = 500, max_boxes_count = 500, max_lines_count = 100)

// ---------------------------------------------------------------- inputs ---
grpVol   = "Volume engine"
ltfIn    = input.timeframe("", "Lower timeframe (blank = auto)", group = grpVol,
     tooltip = "Intrabar timeframe used to split volume into buy/sell. Blank = picked automatically from the chart timeframe.")
grpCndl  = "Candles & footprint"
cndlMode = input.string("Volume split", "Candle style", group = grpCndl,
     options = ["Volume split", "Delta candles"],
     tooltip = "Volume split: each bar shows buy volume (green, from the low) vs sell volume (red, to the high). Delta candles: normal candles colored by delta.")
showFp   = input.bool(true,  "Show footprint cells",        group = grpCndl)
fpBars   = input.int(14,     "Footprint: last N bars",      group = grpCndl, minval = 2,  maxval = 60)
fpRows   = input.int(3,      "Footprint: rows per candle",  group = grpCndl, minval = 2,  maxval = 8)
fpFill   = input.bool(false, "Fill footprint cells",        group = grpCndl)
imbRatio = input.float(3.0,  "Imbalance ratio (x)",         group = grpCndl, minval = 1.5, step = 0.5)
showLbl  = input.bool(true,  "Show volume/probability labels", group = grpCndl)
lblBars  = input.int(20,     "Labels: last N bars",         group = grpCndl, minval = 2, maxval = 120)
grpSig   = "Signals & probability"
rsiLen   = input.int(14,     "RSI length",                  group = grpSig, minval = 2)
emaFLen  = input.int(21,     "Fast EMA",                    group = grpSig, minval = 2)
emaSLen  = input.int(50,     "Slow EMA",                    group = grpSig, minval = 3)
probThr  = input.int(65,     "Signal probability threshold %", group = grpSig, minval = 50, maxval = 95)
dpThr    = input.float(15,   "Min |delta| % to confirm",       group = grpSig, minval = 0, maxval = 60)
sigGap   = input.int(10,     "Min bars between signals",       group = grpSig, minval = 0)
useHtf   = input.bool(true,  "Higher-timeframe trend filter",  group = grpSig, inline = "htf")
htfIn    = input.timeframe("", "",                             group = grpSig, inline = "htf",
     tooltip = "Blank = picked automatically (e.g. chart 15m -> HTF 4h).")
htfLen   = input.int(50,     "HTF EMA length",                 group = grpSig, minval = 5)
showRisk = input.bool(true,  "Show SL/TP on signals",          group = grpSig)
rrRatio  = input.float(2.0,  "Take-profit R:R",                group = grpSig, minval = 0.5, step = 0.5)
grpSr    = "Support / Resistance"
showSr   = input.bool(true,  "Show support/resistance lines", group = grpSr)
srLen    = input.int(10,     "Pivot strength (bars)",  group = grpSr, minval = 2,
     tooltip = "A pivot needs this many lower highs / higher lows on each side. Bigger = stronger, fewer levels.")
srCount  = input.int(3,      "Levels per side",        group = grpSr, minval = 1, maxval = 5)
grpFib   = "Fibonacci"
showFib  = input.bool(true,  "Show fibonacci levels",  group = grpFib)
fibLen   = input.int(120,    "Swing lookback (bars)",  group = grpFib, minval = 20)
grpUi    = "Dashboard"
tblPos   = input.string("Top right", "Dashboard position", group = grpUi,
     options = ["Top right", "Top left", "Bottom right", "Bottom left"])
grpScr   = "Binance screener (left side)"
showScr  = input.bool(true, "Show pair screener", group = grpScr,
     tooltip = "Watches these pairs on the chart timeframe and shows which have a BUY/SELL state right now. Edit the list to any Binance pairs you like.")
sym01 = input.symbol("BINANCE:BTCUSDT",  "1",  group = grpScr, inline = "sa")
sym02 = input.symbol("BINANCE:ETHUSDT",  "2",  group = grpScr, inline = "sa")
sym03 = input.symbol("BINANCE:BNBUSDT",  "3",  group = grpScr, inline = "sb")
sym04 = input.symbol("BINANCE:SOLUSDT",  "4",  group = grpScr, inline = "sb")
sym05 = input.symbol("BINANCE:XRPUSDT",  "5",  group = grpScr, inline = "sc")
sym06 = input.symbol("BINANCE:DOGEUSDT", "6",  group = grpScr, inline = "sc")
sym07 = input.symbol("BINANCE:ADAUSDT",  "7",  group = grpScr, inline = "sd")
sym08 = input.symbol("BINANCE:AVAXUSDT", "8",  group = grpScr, inline = "sd")
sym09 = input.symbol("BINANCE:LINKUSDT", "9",  group = grpScr, inline = "se")
sym10 = input.symbol("BINANCE:DOTUSDT",  "10", group = grpScr, inline = "se")
sym11 = input.symbol("BINANCE:LTCUSDT",  "11", group = grpScr, inline = "sf")
sym12 = input.symbol("BINANCE:NEARUSDT", "12", group = grpScr, inline = "sf")

// ------------------------------------------------------------- utilities ---
fmtVol(float v) =>
    a = math.abs(v)
    a >= 1e9 ? str.tostring(v / 1e9, "#.##") + "B" :
     a >= 1e6 ? str.tostring(v / 1e6, "#.##") + "M" :
     a >= 1e3 ? str.tostring(v / 1e3, "#.#")  + "K" :
     str.tostring(v, "#.##")

autoLtf() =>
    s = timeframe.in_seconds(timeframe.period)
    s >= 86400 ? "30" : s >= 14400 ? "15" : s >= 3600 ? "5" : s >= 300 ? "1" : timeframe.period

autoHtf() =>
    s = timeframe.in_seconds(timeframe.period)
    s <= 300 ? "60" : s <= 3600 ? "240" : s <= 14400 ? "D" : "W"

ltf = ltfIn == "" ? autoLtf() : ltfIn
htf = htfIn == "" ? autoHtf() : htfIn

// ------------------------------------------------- buy / sell volume (LTF) ---
[ltfO, ltfC, ltfV] = request.security_lower_tf(syminfo.tickerid, ltf, [open, close, volume])

float buyVol  = 0.0
float sellVol = 0.0
bool  haveLtf = array.size(ltfV) > 0
if haveLtf
    for i = 0 to array.size(ltfV) - 1
        v = nz(array.get(ltfV, i))
        if array.get(ltfC, i) > array.get(ltfO, i)
            buyVol += v
        else if array.get(ltfC, i) < array.get(ltfO, i)
            sellVol += v
        else
            buyVol  += v / 2
            sellVol += v / 2
else
    rng = high - low
    bp  = rng > 0 ? (close - low) / rng : 0.5
    buyVol  := nz(volume) * bp
    sellVol := nz(volume) * (1 - bp)

delta    = buyVol - sellVol
totVol   = buyVol + sellVol
deltaPct = totVol > 0 ? 100 * delta / totVol : 0.0
var float cumDelta = 0.0
if barstate.isconfirmed
    cumDelta += delta

// ------------------------------------------------------- indicators used ---
rsi  = ta.rsi(close, rsiLen)
emaF = ta.ema(close, emaFLen)
emaS = ta.ema(close, emaSLen)

// -------------------------------------------------- next-candle probability ---
dSign = delta > 0 ? 1 : 0
rZone = rsi < 40 ? 0 : rsi > 60 ? 2 : 1
tSign = emaF > emaS ? 1 : 0
state = dSign * 6 + rZone * 2 + tSign

var int[] stTotal = array.new_int(12, 0)
var int[] stUp    = array.new_int(12, 0)
var int   prevState = -1
if barstate.isconfirmed
    if prevState >= 0
        array.set(stTotal, prevState, array.get(stTotal, prevState) + 1)
        if close > open
            array.set(stUp, prevState, array.get(stUp, prevState) + 1)
    prevState := state

histP    = (array.get(stUp, state) + 1.0) / (array.get(stTotal, state) + 2.0)
deltaSc  = totVol > 0 ? buyVol / totVol : 0.5
rsiSc    = math.max(0.0, math.min(1.0, rsi / 100))
atrVal   = ta.atr(14)
trendSc  = atrVal > 0 ? math.max(0.0, math.min(1.0, 0.5 + (emaF - emaS) / (4 * atrVal))) : 0.5
probUp   = 100 * (0.45 * histP + 0.30 * deltaSc + 0.15 * rsiSc + 0.10 * trendSc)
probUp  := math.max(1, math.min(99, probUp))
probDown = 100 - probUp

// ------------------------------------------------- support / resistance ---
ph = ta.pivothigh(high, srLen, srLen)
pl = ta.pivotlow(low,  srLen, srLen)
var float[] resLv = array.new_float()
var float[] supLv = array.new_float()
if not na(ph) and barstate.isconfirmed
    array.unshift(resLv, ph)
    if array.size(resLv) > srCount
        array.pop(resLv)
if not na(pl) and barstate.isconfirmed
    array.unshift(supLv, pl)
    if array.size(supLv) > srCount
        array.pop(supLv)

var line[]  srLines  = array.new_line()
var label[] srLabels = array.new_label()
if showSr and barstate.islast
    while array.size(srLines) > 0
        line.delete(array.pop(srLines))
    while array.size(srLabels) > 0
        label.delete(array.pop(srLabels))
    if array.size(resLv) > 0
        for i = 0 to array.size(resLv) - 1
            p = array.get(resLv, i)
            array.push(srLines, line.new(math.max(0, bar_index - 80), p, bar_index + 8, p,
                 color = color.new(color.rgb(242, 54, 69), i * 15), width = i == 0 ? 2 : 1))
            if i == 0
                array.push(srLabels, label.new(bar_index + 8, p, "R " + str.tostring(p, format.mintick),
                     style = label.style_none, textcolor = color.rgb(242, 54, 69), size = size.small))
    if array.size(supLv) > 0
        for i = 0 to array.size(supLv) - 1
            p = array.get(supLv, i)
            array.push(srLines, line.new(math.max(0, bar_index - 80), p, bar_index + 8, p,
                 color = color.new(color.rgb(8, 153, 129), i * 15), width = i == 0 ? 2 : 1))
            if i == 0
                array.push(srLabels, label.new(bar_index + 8, p, "S " + str.tostring(p, format.mintick),
                     style = label.style_none, textcolor = color.rgb(8, 153, 129), size = size.small))

// ------------------------------------------------------------- fibonacci ---
hh    = ta.highest(high, fibLen)
ll    = ta.lowest(low,  fibLen)
hhBar = ta.highestbars(high, fibLen)
llBar = ta.lowestbars(low,  fibLen)
upSwing = hhBar > llBar
fibRange = hh - ll
fibAt(float r) => upSwing ? hh - fibRange * r : ll + fibRange * r

var float[] fibRatios = array.from(0.0, 0.236, 0.382, 0.5, 0.618, 0.786, 1.0)
float nearFibPrice = na
float nearFibRatio = na
float bestDist = na
for i = 0 to array.size(fibRatios) - 1
    r  = array.get(fibRatios, i)
    p  = fibAt(r)
    d  = math.abs(close - p)
    if na(bestDist) or d < bestDist
        bestDist     := d
        nearFibPrice := p
        nearFibRatio := r

var line[]  fibLines  = array.new_line()
var label[] fibLabels = array.new_label()
if showFib and barstate.islast
    while array.size(fibLines) > 0
        line.delete(array.pop(fibLines))
    while array.size(fibLabels) > 0
        label.delete(array.pop(fibLabels))
    for i = 0 to array.size(fibRatios) - 1
        r = array.get(fibRatios, i)
        p = fibAt(r)
        col = r == 0.5 ? color.new(color.orange, 30) : color.new(color.teal, 55)
        array.push(fibLines, line.new(math.max(0, bar_index - fibLen), p, bar_index + 8, p,
             color = col, style = line.style_dotted, width = r == 0.618 or r == 0.382 ? 2 : 1))
        array.push(fibLabels, label.new(bar_index + 8, p,
             str.tostring(r, "#.###") + "  " + str.tostring(p, format.mintick),
             style = label.style_none, textcolor = col, size = size.small))

// ----------------------------------------------------------- signal logic ---
htfEma    = request.security(syminfo.tickerid, htf, ta.ema(close, htfLen)[1],
     lookahead = barmerge.lookahead_on)
htfBull   = close > htfEma
htfOkBuy  = not useHtf or htfBull
htfOkSell = not useHtf or not htfBull

strongDelta = math.abs(deltaPct) >= dpThr
buyCond  = probUp   >= probThr and delta > 0 and strongDelta and rsi > 40 and rsi < 75 and emaF > emaS and htfOkBuy
sellCond = probDown >= probThr and delta < 0 and strongDelta and rsi < 60 and rsi > 25 and emaF < emaS and htfOkSell

var int lastSigBar = -100000
canSig  = bar_index - lastSigBar >= sigGap
buySig  = buyCond  and not buyCond[1]  and canSig and barstate.isconfirmed
sellSig = sellCond and not sellCond[1] and canSig and barstate.isconfirmed
if buySig or sellSig
    lastSigBar := bar_index

var label[] riskLabels = array.new_label()
if showRisk and (buySig or sellSig)
    slDist = 1.5 * atrVal
    sl = buySig ? close - slDist : close + slDist
    tp = buySig ? close + slDist * rrRatio : close - slDist * rrRatio
    rTxt = (buySig ? "BUY  " : "SELL ") + str.tostring(close, format.mintick) +
         "\nSL " + str.tostring(sl, format.mintick) +
         "\nTP " + str.tostring(tp, format.mintick)
    array.push(riskLabels, label.new(bar_index, buySig ? low : high, rTxt,
         style = buySig ? label.style_label_up : label.style_label_down,
         color = color.new(buySig ? color.rgb(8, 153, 129) : color.rgb(242, 54, 69), 25),
         textcolor = color.white, size = size.small,
         yloc = buySig ? yloc.belowbar : yloc.abovebar))
    while array.size(riskLabels) > 12
        label.delete(array.shift(riskLabels))

// -------------------------------------------------------- candle painting ---
colBuy    = color.rgb(8, 153, 129)
colSell   = color.rgb(242, 54, 69)
isSplit   = cndlMode == "Volume split"

// classic delta candles (only in "Delta candles" mode)
strength  = math.min(math.abs(deltaPct), 60) / 60
bodyCol   = delta >= 0 ?
     color.new(colBuy,  int(55 - 45 * strength)) :
     color.new(colSell, int(55 - 45 * strength))
edgeCol   = delta >= 0 ? colBuy : colSell
plotcandle(isSplit ? na : open, isSplit ? na : high, isSplit ? na : low, isSplit ? na : close,
     title = "Delta candles", color = bodyCol, wickcolor = edgeCol, bordercolor = edgeCol)

// volume-split candles: green body = buy share of the bar's range, red = sell
buyTop = low + (high - low) * (totVol > 0 ? buyVol / totVol : 0.5)
plotcandle(isSplit ? low : na, isSplit ? buyTop : na, isSplit ? low : na, isSplit ? buyTop : na,
     title = "Buy volume part", color = color.new(colBuy, 15), wickcolor = colBuy, bordercolor = colBuy)
plotcandle(isSplit ? buyTop : na, isSplit ? high : na, isSplit ? buyTop : na, isSplit ? high : na,
     title = "Sell volume part", color = color.new(colSell, 15), wickcolor = colSell, bordercolor = colSell)

plotshape(buySig,  title = "BUY signal",  style = shape.triangleup,
     location = location.belowbar, color = colBuy,  size = size.small, text = "BUY")
plotshape(sellSig, title = "SELL signal", style = shape.triangledown,
     location = location.abovebar, color = colSell, size = size.small, text = "SELL")

// -------------------------------------------------------- footprint cells ---
var box[] fpBoxes = array.new_box()
if showFp and barstate.isconfirmed and haveLtf
    rng = high - low
    if rng > 0
        rowBuy  = array.new_float(fpRows, 0.0)
        rowSell = array.new_float(fpRows, 0.0)
        for i = 0 to array.size(ltfV) - 1
            p   = array.get(ltfC, i)
            idx = math.max(0, math.min(fpRows - 1, int(math.floor((p - low) / rng * fpRows))))
            v   = nz(array.get(ltfV, i))
            if array.get(ltfC, i) >= array.get(ltfO, i)
                array.set(rowBuy, idx, array.get(rowBuy, idx) + v)
            else
                array.set(rowSell, idx, array.get(rowSell, idx) + v)
        for r2 = 0 to fpRows - 1
            b = array.get(rowBuy, r2)
            s = array.get(rowSell, r2)
            if b + s > 0
                yB = low + rng * r2 / fpRows
                yT = low + rng * (r2 + 1) / fpRows
                buyImb  = s > 0 ? b / s >= imbRatio : b > 0
                sellImb = b > 0 ? s / b >= imbRatio : s > 0
                imb     = buyImb or sellImb
                bCol = imb ? color.new(color.orange, 0) : color.new(color.gray, 100)
                fCol = fpFill ? (b >= s ? color.new(colBuy, 88) : color.new(colSell, 88)) : color.new(color.gray, 100)
                tCol = b >= s ? color.new(colBuy, 0) : color.new(colSell, 0)
                array.push(fpBoxes, box.new(bar_index, yT, bar_index, yB,
                     border_color = bCol, border_width = 1,
                     bgcolor = fCol, text = fmtVol(s) + " x " + fmtVol(b),
                     text_size = size.tiny, text_color = tCol))
    while array.size(fpBoxes) > fpBars * fpRows
        box.delete(array.shift(fpBoxes))

// ------------------------------------------------- per-candle info labels ---
var label[] volLabels = array.new_label()
if showLbl and barstate.isconfirmed
    txtTop = "B:" + fmtVol(buyVol) + "\nS:" + fmtVol(sellVol)
    array.push(volLabels, label.new(bar_index, high, txtTop,
         style = label.style_none, textcolor = color.new(color.rgb(66, 135, 245), 10),
         size = size.tiny, yloc = yloc.abovebar))
    txtBot = (delta >= 0 ? "+" : "") + fmtVol(delta) + "\n" +
         (probUp >= 50 ? "▲" + str.tostring(probUp, "#") : "▼" + str.tostring(probDown, "#")) + "%"
    array.push(volLabels, label.new(bar_index, low, txtBot,
         style = label.style_none, textcolor = delta >= 0 ? colBuy : colSell,
         size = size.tiny, yloc = yloc.belowbar))
    while array.size(volLabels) > lblBars * 2
        label.delete(array.shift(volLabels))

// ------------------------------------------------------ screener (left) ---
// Simplified per-pair state on the chart timeframe: trend (EMA), RSI zone and
// close-location volume pressure. 1 = BUY state, -1 = SELL state, 0 = wait.
screenState() =>
    eF  = ta.ema(close, emaFLen)
    eS  = ta.ema(close, emaSLen)
    r   = ta.rsi(close, rsiLen)
    rg  = high - low
    bp  = rg > 0 ? (close - low) / rg : 0.5
    dP  = (2 * bp - 1) * 100
    b   = dP >= dpThr and r > 40 and r < 75 and eF > eS
    sS  = dP <= -dpThr and r < 60 and r > 25 and eF < eS
    b ? 1 : sS ? -1 : 0

sc01 = request.security(sym01, timeframe.period, screenState())
sc02 = request.security(sym02, timeframe.period, screenState())
sc03 = request.security(sym03, timeframe.period, screenState())
sc04 = request.security(sym04, timeframe.period, screenState())
sc05 = request.security(sym05, timeframe.period, screenState())
sc06 = request.security(sym06, timeframe.period, screenState())
sc07 = request.security(sym07, timeframe.period, screenState())
sc08 = request.security(sym08, timeframe.period, screenState())
sc09 = request.security(sym09, timeframe.period, screenState())
sc10 = request.security(sym10, timeframe.period, screenState())
sc11 = request.security(sym11, timeframe.period, screenState())
sc12 = request.security(sym12, timeframe.period, screenState())

var table scr = table.new(position.middle_left, 2, 13, bgcolor = color.new(chart.bg_color, 15),
     border_color = color.new(color.gray, 60), border_width = 1)
scRow(int row, string sym, int st) =>
    if showScr and barstate.islast
        nm = str.replace(sym, "BINANCE:", "")
        table.cell(scr, 0, row, nm, text_color = chart.fg_color, text_size = size.tiny)
        stTxt = st == 1 ? "BUY" : st == -1 ? "SELL" : "—"
        stCol = st == 1 ? color.rgb(8, 153, 129) : st == -1 ? color.rgb(242, 54, 69) : color.gray
        table.cell(scr, 1, row, stTxt, text_color = color.white, text_size = size.tiny,
             bgcolor = st == 0 ? color.new(color.gray, 80) : color.new(stCol, 25))

if showScr and barstate.islast
    table.cell(scr, 0, 0, "Screener", text_color = color.rgb(66, 135, 245), text_size = size.tiny)
    table.cell(scr, 1, 0, timeframe.period, text_color = color.rgb(66, 135, 245), text_size = size.tiny)
scRow(1,  sym01, sc01)
scRow(2,  sym02, sc02)
scRow(3,  sym03, sc03)
scRow(4,  sym04, sc04)
scRow(5,  sym05, sc05)
scRow(6,  sym06, sc06)
scRow(7,  sym07, sc07)
scRow(8,  sym08, sc08)
scRow(9,  sym09, sc09)
scRow(10, sym10, sc10)
scRow(11, sym11, sc11)
scRow(12, sym12, sc12)

// -------------------------------------------------------------- dashboard ---
pos = tblPos == "Top right" ? position.top_right :
     tblPos == "Top left" ? position.top_left :
     tblPos == "Bottom right" ? position.bottom_right : position.bottom_left
var table dash = table.new(pos, 2, 11, bgcolor = color.new(chart.bg_color, 15),
     border_color = color.new(color.gray, 60), border_width = 1)
if barstate.islast
    hdr = color.new(color.rgb(66, 135, 245), 0)
    fg  = chart.fg_color
    table.cell(dash, 0, 0, "NaatAI OFC", text_color = hdr, text_size = size.small)
    table.cell(dash, 1, 0, timeframe.period, text_color = hdr, text_size = size.small)
    table.cell(dash, 0, 1, "Buy Vol",  text_color = fg, text_size = size.small)
    table.cell(dash, 1, 1, fmtVol(buyVol),  text_color = colBuy,  text_size = size.small)
    table.cell(dash, 0, 2, "Sell Vol", text_color = fg, text_size = size.small)
    table.cell(dash, 1, 2, fmtVol(sellVol), text_color = colSell, text_size = size.small)
    table.cell(dash, 0, 3, "Delta",    text_color = fg, text_size = size.small)
    table.cell(dash, 1, 3, (delta >= 0 ? "+" : "") + fmtVol(delta) + "  (" + str.tostring(deltaPct, "#.#") + "%)",
         text_color = delta >= 0 ? colBuy : colSell, text_size = size.small)
    table.cell(dash, 0, 4, "Cum Delta", text_color = fg, text_size = size.small)
    table.cell(dash, 1, 4, (cumDelta >= 0 ? "+" : "") + fmtVol(cumDelta),
         text_color = cumDelta >= 0 ? colBuy : colSell, text_size = size.small)
    table.cell(dash, 0, 5, "RSI(" + str.tostring(rsiLen) + ")", text_color = fg, text_size = size.small)
    table.cell(dash, 1, 5, str.tostring(rsi, "#.#"),
         text_color = rsi > 70 ? colSell : rsi < 30 ? colBuy : fg, text_size = size.small)
    table.cell(dash, 0, 6, "Support",    text_color = fg, text_size = size.small)
    table.cell(dash, 1, 6, array.size(supLv) > 0 ? str.tostring(array.get(supLv, 0), format.mintick) : "—",
         text_color = colBuy, text_size = size.small)
    table.cell(dash, 0, 7, "Resistance", text_color = fg, text_size = size.small)
    table.cell(dash, 1, 7, array.size(resLv) > 0 ? str.tostring(array.get(resLv, 0), format.mintick) : "—",
         text_color = colSell, text_size = size.small)
    table.cell(dash, 0, 8, "Next candle", text_color = fg, text_size = size.small)
    table.cell(dash, 1, 8, "▲ " + str.tostring(probUp, "#") + "%   ▼ " + str.tostring(probDown, "#") + "%",
         text_color = probUp >= 50 ? colBuy : colSell, text_size = size.small)
    table.cell(dash, 0, 9, "HTF trend (" + htf + ")", text_color = fg, text_size = size.small)
    table.cell(dash, 1, 9, htfBull ? "UP" : "DOWN",
         text_color = htfBull ? colBuy : colSell, text_size = size.small)
    sigTxt = buyCond ? "BUY" : sellCond ? "SELL" : "WAIT"
    table.cell(dash, 0, 10, "Signal", text_color = fg, text_size = size.small)
    table.cell(dash, 1, 10, sigTxt,
         text_color = buyCond ? colBuy : sellCond ? colSell : color.gray, text_size = size.small)

// ------------------------------------------------------------------ alerts ---
alertcondition(buySig,  "NaatAI BUY",  "NaatAI OFC: BUY signal — bullish probability above threshold")
alertcondition(sellSig, "NaatAI SELL", "NaatAI OFC: SELL signal — bearish probability above threshold")
