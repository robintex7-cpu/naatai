//@version=6
// NaatAI Heiken Ashi + PC Trend
// -----------------------------
// TradingView combination of the two MT4 indicators from the Binary Breaker
// template: "Heiken_Ashi" + "PCTrendA" (length 16), in ONE pane.
//   * Heiken Ashi candles (MT4 default colors: red down / white up — changeable)
//   * PC Trend line colored by direction, with dots at every color change
//   * BUY/SELL signals when HA color and PC Trend direction align (candle close,
//     non-repainting — the MT4 PCTrendA could repaint; this version cannot)
//   * Timeframe selector — view any timeframe independently of the main chart
//   * Hidden "HA Close" plot so you can apply ANY other TradingView indicator
//     on this pane (set that indicator's Source to "NaatAI HA+PC: HA Close")
indicator("NaatAI Heiken Ashi + PC Trend", "NaatAI HA+PC", overlay = false, format = format.price)

// ---------------------------------------------------------------- inputs ---
haTf     = input.timeframe("", "Timeframe (blank = chart timeframe)")
grpHa    = "Heiken Ashi"
colDn    = input.color(color.rgb(255, 60, 60),    "Down candle", group = grpHa, inline = "c")
colUp    = input.color(color.rgb(235, 235, 235),  "Up candle",   group = grpHa, inline = "c",
     tooltip = "MT4 template defaults: red down / white up. Pick green/red if you prefer TradingView style.")
grpPct   = "PC Trend (PCTrendA)"
showPct  = input.bool(true, "Show PC Trend line", group = grpPct)
pctLen   = input.int(16,    "Length",             group = grpPct, minval = 2)
pctUpCol = input.color(color.rgb(41, 98, 255),  "Trend up",   group = grpPct, inline = "p")
pctDnCol = input.color(color.rgb(255, 140, 0),  "Trend down", group = grpPct, inline = "p")
pctFlip  = input.bool(true, "Mark trend color changes", group = grpPct)
grpSig   = "Signals"
showSig  = input.bool(true, "BUY/SELL when HA + PC Trend align", group = grpSig)
grpUi    = "Dashboard"
showTbl  = input.bool(true, "Show dashboard", group = grpUi)
tblPos   = input.string("Top right", "Position", group = grpUi,
     options = ["Top right", "Top left", "Bottom right", "Bottom left"])

// -------------------------------------------------------- heiken ashi data ---
haTicker = ticker.heikinashi(syminfo.tickerid)
[haO, haH, haL, haC] = request.security(haTicker, haTf, [open, high, low, close],
     gaps = barmerge.gaps_off, lookahead = barmerge.lookahead_off)
haUp = haC >= haO

// ------------------------------------------------------------- PC Trend ---
// Recreation of MT4 "PCTrendA": a low-lag (Hull-style) moving average of the
// HA close, colored by its slope.
hmaOf(src, int len) =>
    half = math.max(1, int(math.floor(len / 2.0)))
    rt   = math.max(1, int(math.floor(math.sqrt(len))))
    ta.wma(2 * ta.wma(src, half) - ta.wma(src, len), rt)

pcLine = hmaOf(haC, pctLen)
pcUp   = pcLine > pcLine[1]
pcCol  = pcUp ? pctUpCol : pctDnCol

// ------------------------------------------------------------------ plots ---
plotcandle(haO, haH, haL, haC, title = "Heiken Ashi",
     color = haUp ? colUp : colDn,
     wickcolor = haUp ? colUp : colDn,
     bordercolor = haUp ? colUp : colDn)

plot(showPct ? pcLine : na, "PC Trend", color = pcCol, linewidth = 2)
plotshape(showPct and pctFlip and pcUp and not pcUp[1] ? pcLine : na, "PC flip up",
     style = shape.circle, location = location.absolute, color = pctUpCol, size = size.tiny)
plotshape(showPct and pctFlip and not pcUp and pcUp[1] ? pcLine : na, "PC flip down",
     style = shape.circle, location = location.absolute, color = pctDnCol, size = size.tiny)

// Hidden source plot: apply any other indicator on this pane by choosing
// Source = "NaatAI HA+PC: HA Close" in that indicator's settings.
plot(haC, "HA Close", display = display.none, editable = false)

// ---------------------------------------------------------------- signals ---
// BUY  = Heiken Ashi turns/is up AND PC Trend points up (first bar both agree)
// SELL = Heiken Ashi turns/is down AND PC Trend points down
comboUp = haUp and (not showPct or pcUp)
comboDn = not haUp and (not showPct or not pcUp)
buySig  = comboUp and not comboUp[1] and barstate.isconfirmed
sellSig = comboDn and not comboDn[1] and barstate.isconfirmed
plotshape(showSig and buySig,  title = "BUY (HA + PC Trend)",  style = shape.triangleup,
     location = location.bottom, color = color.rgb(8, 153, 129), size = size.tiny, text = "BUY")
plotshape(showSig and sellSig, title = "SELL (HA + PC Trend)", style = shape.triangledown,
     location = location.top, color = color.rgb(242, 54, 69), size = size.tiny, text = "SELL")

// -------------------------------------------------------------- dashboard ---
gCol = color.rgb(8, 153, 129)
rCol = color.rgb(242, 54, 69)
pos = tblPos == "Top right" ? position.top_right :
     tblPos == "Top left" ? position.top_left :
     tblPos == "Bottom right" ? position.bottom_right : position.bottom_left
var table dash = table.new(pos, 2, 4, bgcolor = color.new(chart.bg_color, 15),
     border_color = color.new(color.gray, 60), border_width = 1)
if showTbl and barstate.islast
    fg  = chart.fg_color
    hdr = color.new(color.rgb(66, 135, 245), 0)
    table.cell(dash, 0, 0, "HA + PC Trend", text_color = hdr, text_size = size.small)
    table.cell(dash, 1, 0, haTf == "" ? timeframe.period : haTf, text_color = hdr, text_size = size.small)
    table.cell(dash, 0, 1, "Heiken Ashi", text_color = fg, text_size = size.small)
    table.cell(dash, 1, 1, haUp ? "UP" : "DOWN", text_color = haUp ? gCol : rCol, text_size = size.small)
    table.cell(dash, 0, 2, "PC Trend", text_color = fg, text_size = size.small)
    table.cell(dash, 1, 2, pcUp ? "UP" : "DOWN", text_color = pcUp ? gCol : rCol, text_size = size.small)
    stTxt = comboUp ? "LONG" : comboDn ? "SHORT" : "MIXED"
    table.cell(dash, 0, 3, "State", text_color = fg, text_size = size.small)
    table.cell(dash, 1, 3, stTxt,
         text_color = comboUp ? gCol : comboDn ? rCol : color.gray, text_size = size.small)

// ------------------------------------------------------------------ alerts ---
alertcondition(buySig,  "HA+PC BUY",  "Heiken Ashi + PC Trend aligned UP")
alertcondition(sellSig, "HA+PC SELL", "Heiken Ashi + PC Trend aligned DOWN")
alertcondition(pcUp and not pcUp[1],   "PC Trend flip UP",   "PC Trend line turned up")
alertcondition(not pcUp and pcUp[1],   "PC Trend flip DOWN", "PC Trend line turned down")
