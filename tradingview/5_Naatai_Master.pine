//@version=5
// =============================================================================
// NAATAI MASTER v4 — quality-first signals
//   Core confirmations (your two most important): PCTrend + BB_Trigger(Ergodic)
//   Extra filters/context: Parabolic SAR, EMA trend context, Heiken Ashi
//   Tools drawn: Support/Resistance, Fibonacci, PSAR dots, reversal markers
//
// QUALITY RULE: a BUY/SELL fires only on the bar where ALL required
// confirmations FIRST agree (a state change) — not on every trending bar.
// Then it stays silent until they break and realign. This is what removes the
// "BUY-BUY-BUY / SELL-SELL-SELL" clusters.
//
// No repaint: channel/pivots use past bars, signals confirm on close.
// =============================================================================
indicator("Naatai Master (Breakout + HA + PCTrend + Ergodic)", overlay = true, max_lines_count = 500)

// ----------------------------------------------------------------- display ---
gM        = "Display"
showHA    = input.bool(false, "Heiken Ashi candles", group = gM)
showChan  = input.bool(true,  "PCTrend channel",  group = gM)
colorBars = input.bool(true,  "Colour bars by trend", group = gM)
showSig   = input.bool(true,  "BUY/SELL signals",  group = gM)
showLevels= input.bool(true,  "Entry / Stop / Target lines", group = gM)
showPSAR  = input.bool(true,  "Parabolic SAR dots", group = gM)
showSR    = input.bool(true,  "Support / Resistance", group = gM)
showFib   = input.bool(false, "Fibonacci levels", group = gM)
showRev   = input.bool(true,  "Trend-reversal markers", group = gM)
showTable = input.bool(true,  "Status table",      group = gM)

// ------------------------------------------------- signal confirmations ------
// Your two most important are ON and recommended to stay ON.
gC        = "Signal confirmations (quality)"
reqPCTrend = input.bool(true,  "Require PCTrend agreement  (KEY)", group = gC)
reqErgodic = input.bool(true,  "Require Ergodic CCI agreement  (KEY)", group = gC)
reqPSAR    = input.bool(true,  "Require Parabolic SAR agreement", group = gC)
reqContext = input.bool(true,  "Require EMA trend-context agreement", group = gC)
reqHA      = input.bool(false, "Require Heiken Ashi agreement", group = gC)
confirm    = input.bool(true,  "Confirm on bar close (no repaint)", group = gC)
cooldown   = input.int(8,      "Min bars between signals", minval = 0, group = gC)

// ------------------------------------------------------------------ PCTrend --
gPC      = "PCTrendA"
length   = input.int(16, "Length", minval = 1, group = gPC)
upCol    = input.color(color.rgb(255, 140, 0), "Up trend",   group = gPC)
dnCol    = input.color(color.rgb(0, 0, 255),   "Down trend", group = gPC)
// ------------------------------------------------------- BB_Trigger Ergodic --
gBB     = "BB_Trigger (Ergodic CCI)"
pq      = input.int(2,  "pq (1st smoothing)", minval = 1, group = gBB)
pr      = input.int(10, "pr (CCI length)",    minval = 1, group = gBB)
ps      = input.int(5,  "ps (2nd smoothing)", minval = 1, group = gBB)
trigger = input.int(3,  "trigger (signal)",   minval = 1, group = gBB)
// ----------------------------------------------------------- Parabolic SAR --
gSAR    = "Parabolic SAR"
sarStart = input.float(0.02, "Start",     step = 0.01, group = gSAR)
sarInc   = input.float(0.02, "Increment", step = 0.01, group = gSAR)
sarMax   = input.float(0.20, "Max",       step = 0.01, group = gSAR)
// ----------------------------------------------------- support / resistance --
gSR      = "Support / Resistance + Fib"
pivLeft  = input.int(5, "Pivot left",  minval = 1, group = gSR)
pivRight = input.int(5, "Pivot right", minval = 1, group = gSR)
fibLook  = input.int(50, "Fibonacci swing lookback", minval = 10, group = gSR)
// ------------------------------------------------------------- Heiken Ashi ---
gHA     = "Heiken Ashi"
haUpCol = input.color(color.white, "Up candle",   group = gHA)
haDnCol = input.color(color.red,   "Down candle", group = gHA)
// risk
gR      = "Risk"
atrLen  = input.int(14, "ATR length", minval = 1, group = gR)

// =============================================================================
// Maths
// =============================================================================
atr = ta.atr(atrLen)

// ---- Heiken Ashi ----
haClose = (open + high + low + close) / 4.0
var float haOpen = na
haOpen := na(haOpen[1]) ? (open + close) / 2.0 : (haOpen[1] + haClose[1]) / 2.0
haHigh  = math.max(high, math.max(haOpen, haClose))
haLow   = math.min(low,  math.min(haOpen, haClose))
haBull  = haClose >= haOpen
plotcandle(showHA ? haOpen : na, showHA ? haHigh : na, showHA ? haLow : na, showHA ? haClose : na,
     title = "Heiken Ashi", color = haBull ? haUpCol : haDnCol,
     wickcolor = haBull ? haUpCol : haDnCol, bordercolor = haBull ? haUpCol : haDnCol)

// ---- PCTrend (price-channel breakout trend; previous bar = no repaint) ----
upper = ta.highest(high, length)
lower = ta.lowest(low,  length)
var int trend = 0
trend := close > upper[1] ? 1 : close < lower[1] ? -1 : nz(trend[1], 0)
trendUp = trend > 0
trendDn = trend < 0
trendCol = trendUp ? upCol : trendDn ? dnCol : color.gray
barcolor(colorBars ? trendCol : na)
plot(showChan ? upper : na, "Channel High", color = color.new(upCol, 70))
plot(showChan ? lower : na, "Channel Low",  color = color.new(dnCol, 70))

// ---- Ergodic CCI ----
cci     = ta.cci(hlc3, pr)
ergodic = ta.ema(ta.ema(cci, pq), ps)
trig    = ta.ema(ergodic, trigger)
ergBull = ergodic > trig
ergBear = ergodic < trig

// ---- Parabolic SAR ----
psar    = ta.sar(sarStart, sarInc, sarMax)
psarBull = close > psar
psarBear = close < psar
plot(showPSAR ? psar : na, "PSAR", style = plot.style_cross,
     color = psarBull ? color.new(color.green, 0) : color.new(color.red, 0))

// ---- EMA trend context ----
emaFast = ta.ema(close, 20)
emaSlow = ta.ema(close, 50)
upCtx   = emaFast > emaSlow and close > emaSlow
dnCtx   = emaFast < emaSlow and close < emaSlow

// ---- Support / Resistance from swing pivots (confirmed = no repaint) ----
ph = ta.pivothigh(high, pivLeft, pivRight)
pl = ta.pivotlow(low,  pivLeft, pivRight)
var float resLvl = na
var float supLvl = na
resLvl := na(ph) ? resLvl : ph
supLvl := na(pl) ? supLvl : pl
plot(showSR ? resLvl : na, "Resistance", color = color.new(color.red, 30),  style = plot.style_stepline)
plot(showSR ? supLvl : na, "Support",    color = color.new(color.green, 30), style = plot.style_stepline)

// ---- Fibonacci (auto, from rolling swing over fibLook) ----
swH  = ta.highest(high, fibLook)
swL  = ta.lowest(low,  fibLook)
dif  = swH - swL
fib382 = swH - 0.382 * dif
fib500 = swH - 0.500 * dif
fib618 = swH - 0.618 * dif
plot(showFib ? fib382 : na, "Fib 0.382", color = color.new(color.teal, 40), style = plot.style_stepline)
plot(showFib ? fib500 : na, "Fib 0.5",   color = color.new(color.teal, 20), style = plot.style_stepline)
plot(showFib ? fib618 : na, "Fib 0.618", color = color.new(color.teal, 40), style = plot.style_stepline)

// =============================================================================
// QUALITY SIGNALS — fire only when required confirmations FIRST agree
// =============================================================================
bull = (not reqPCTrend or trendUp) and (not reqErgodic or ergBull) and (not reqPSAR or psarBull) and (not reqContext or upCtx) and (not reqHA or haBull)
bear = (not reqPCTrend or trendDn) and (not reqErgodic or ergBear) and (not reqPSAR or psarBear) and (not reqContext or dnCtx) and (not reqHA or not haBull)

buyTrigger  = bull and not bull[1]     // the bar alignment turns bullish
sellTrigger = bear and not bear[1]
gate = confirm ? barstate.isconfirmed : true

var int lastSigBar = -1
coolOK = lastSigBar < 0 or (bar_index - lastSigBar) >= cooldown
buySig  = buyTrigger  and gate and coolOK
sellSig = sellTrigger and gate and coolOK
if buySig or sellSig
    lastSigBar := bar_index

plotshape(showSig and buySig,  title = "BUY",  style = shape.labelup,
     location = location.belowbar, color = color.new(color.green, 0),
     text = "BUY", textcolor = color.white, size = size.normal)
plotshape(showSig and sellSig, title = "SELL", style = shape.labeldown,
     location = location.abovebar, color = color.new(color.red, 0),
     text = "SELL", textcolor = color.white, size = size.normal)

// ---- Trend-reversal markers (early warning: PSAR flips) ----
psarFlipUp = psarBull and not psarBull[1]
psarFlipDn = psarBear and not psarBear[1]
plotshape(showRev and psarFlipUp, title = "Rev Up", style = shape.triangleup,
     location = location.belowbar, color = color.new(color.lime, 0), size = size.tiny)
plotshape(showRev and psarFlipDn, title = "Rev Dn", style = shape.triangledown,
     location = location.abovebar, color = color.new(color.maroon, 0), size = size.tiny)

// =============================================================================
// Entry / Stop / Targets — stop rides the Parabolic SAR (min 0.5*ATR away)
// =============================================================================
var float lvlEntry = na
var float lvlStop  = na
var float lvlT1 = na
var float lvlT2 = na
var float lvlT3 = na
if buySig
    lvlEntry := close
    sd = math.max(close - psar, 0.5 * atr)
    lvlStop := close - sd
    lvlT1 := close + sd
    lvlT2 := close + 2 * sd
    lvlT3 := close + 3 * sd
if sellSig
    lvlEntry := close
    sd = math.max(psar - close, 0.5 * atr)
    lvlStop := close + sd
    lvlT1 := close - sd
    lvlT2 := close - 2 * sd
    lvlT3 := close - 3 * sd
plot(showLevels ? lvlEntry : na, "Entry", color = color.new(color.blue, 0),  style = plot.style_linebr)
plot(showLevels ? lvlStop  : na, "Stop",  color = color.new(color.red, 0),   style = plot.style_linebr)
plot(showLevels ? lvlT1    : na, "T1",    color = color.new(color.green, 0),  style = plot.style_linebr)
plot(showLevels ? lvlT2    : na, "T2",    color = color.new(color.green, 30), style = plot.style_linebr)
plot(showLevels ? lvlT3    : na, "T3",    color = color.new(color.green, 60), style = plot.style_linebr)

// =============================================================================
// Alerts
// =============================================================================
alertcondition(buySig,  title = "Naatai BUY",  message = "Naatai BUY {{ticker}} {{interval}} @ {{close}}")
alertcondition(sellSig, title = "Naatai SELL", message = "Naatai SELL {{ticker}} {{interval}} @ {{close}}")
if buySig
    alert("Naatai BUY " + syminfo.ticker + " @ " + str.tostring(close), alert.freq_once_per_bar_close)
if sellSig
    alert("Naatai SELL " + syminfo.ticker + " @ " + str.tostring(close), alert.freq_once_per_bar_close)

// =============================================================================
// Status table
// =============================================================================
var table t = table.new(position.top_right, 2, 6, border_width = 1)
if showTable and barstate.islast
    table.cell(t, 0, 0, "PCTrend", text_color = color.white, bgcolor = color.gray)
    table.cell(t, 1, 0, trendUp ? "UP" : trendDn ? "DOWN" : "FLAT", text_color = color.white, bgcolor = trendCol)
    table.cell(t, 0, 1, "Ergodic CCI", text_color = color.white, bgcolor = color.gray)
    table.cell(t, 1, 1, ergBull ? "LONG" : ergBear ? "SHORT" : "NEUTRAL", text_color = color.white, bgcolor = ergBull ? color.green : ergBear ? color.red : color.gray)
    table.cell(t, 0, 2, "Parabolic SAR", text_color = color.white, bgcolor = color.gray)
    table.cell(t, 1, 2, psarBull ? "UP" : "DOWN", text_color = color.white, bgcolor = psarBull ? color.green : color.red)
    table.cell(t, 0, 3, "Heiken Ashi", text_color = color.white, bgcolor = color.gray)
    table.cell(t, 1, 3, haBull ? "BULL" : "BEAR", text_color = color.white, bgcolor = haBull ? color.green : color.red)
    table.cell(t, 0, 4, "Context", text_color = color.white, bgcolor = color.gray)
    table.cell(t, 1, 4, upCtx ? "UP" : dnCtx ? "DOWN" : "MIXED", text_color = color.white, bgcolor = upCtx ? color.green : dnCtx ? color.red : color.gray)
    overallBias = bull ? "BUY ZONE" : bear ? "SELL ZONE" : "WAIT"
    table.cell(t, 0, 5, "Bias", text_color = color.white, bgcolor = color.gray)
    table.cell(t, 1, 5, overallBias, text_color = color.white, bgcolor = bull ? color.green : bear ? color.red : color.new(color.gray, 30))
